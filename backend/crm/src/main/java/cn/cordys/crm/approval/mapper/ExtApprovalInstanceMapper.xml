<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="cn.cordys.crm.approval.mapper.ExtApprovalInstanceMapper">
    <select id="updateApprovalStatus" resultType="java.lang.String">
        update ${sourceTable} set approval_status = #{approvalStatus} where id = #{id}
    </select>


    <select id="selectBusinessName" resultType="java.lang.String">
        select name from ${sourceTable} where id = #{id}
    </select>
</mapper>